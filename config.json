{
  "frameworks": {
    "react": {
      "packages": ["react", "react-dom"],
      "devDependencies": ["@types/react", "@types/react-dom", "@vitejs/plugin-react"],
      "description": "React library for building UI"
    },
    "next": {
      "packages": ["next", "react", "react-dom"],
      "devDependencies": ["@types/node", "@types/react", "@types/react-dom"],
      "description": "Next.js React framework"
    },
    "vue": {
      "packages": ["vue"],
      "devDependencies": ["@vitejs/plugin-vue"],
      "description": "Vue.js framework"
    },
    "svelte": {
      "packages": ["svelte"],
      "devDependencies": ["@sveltejs/vite-plugin-svelte"],
      "description": "Svelte framework"
    },
    "express": {
      "packages": ["express", "cors", "helmet"],
      "devDependencies": ["@types/express", "@types/node"],
      "description": "Express.js backend framework"
    },
    "react-native": {
      "packages": ["expo", "react", "react-native", "expo-status-bar"],
