      "description": "React Native mobile app (Expo)"
    },
    "fastapi": {
      "packages": [],
      "devDependencies": [],
      "description": "FastAPI Python framework (handled separately)"
    },
    "django": {
      "packages": [],
      "devDependencies": [],
      "description": "Django Python framework (handled separately)"
    }
  },
  "styling": {
    "tailwind": {
      "packages": ["tailwindcss", "postcss", "@tailwindcss/postcss"],
      "devDependencies": [],
      "configFile": "tailwind.config.js",
      "description": "Tailwind CSS utility framework"
    },
    "scss": {
      "packages": ["sass"],
      "devDependencies": [],
      "description": "Sass CSS preprocessor"
    },
    "css": {
      "packages": [],
      "devDependencies": [],
      "description": "Plain CSS"
    },
    "bootstrap": {
      "packages": ["bootstrap"],
      "devDependencies": [],
      "description": "Bootstrap framework"
    },
    "material-ui": {
      "packages": ["@mui/material", "@emotion/react", "@emotion/styled"],
      "devDependencies": [],
      "description": "Material-UI component library"
    },
    "native": {
      "packages": [],
      "devDependencies": [],
      "description": "Native mobile styling"
    }
  },
  "databases": {
    "mongodb": {
      "packages": ["mongoose"],
      "devDependencies": ["@types/mongoose"],
      "description": "MongoDB with Mongoose"
    },
    "postgresql": {
      "packages": ["pg", "sequelize"],
      "devDependencies": ["@types/pg"],
      "description": "PostgreSQL with Sequelize"
    },
    "firebase": {
      "packages": ["firebase", "firebase-admin"],
      "devDependencies": [],
      "description": "Firebase backend"
    },
    "mysql": {
      "packages": ["mysql2", "sequelize"],
      "devDependencies": [],
      "description": "MySQL database"
    },
    "supabase": {
      "packages": ["@supabase/supabase-js"],
      "devDependencies": [],
      "description": "Supabase (PostgreSQL)"
    }
  },
  "utilities": {
    "axios": {
      "packages": ["axios"],
      "devDependencies": ["@types/axios"],
      "description": "HTTP client library"
    },
    "lodash": {
      "packages": ["lodash"],
      "devDependencies": ["@types/lodash"],
      "description": "Utility library"
    },
    "dotenv": {
      "packages": ["dotenv"],
      "devDependencies": [],
      "description": "Environment variable management"
    },
    "jest": {
      "packages": [],
      "devDependencies": ["jest", "@testing-library/react"],
      "description": "Testing framework"
    },
    "eslint": {
      "packages": [],
      "devDependencies": ["eslint", "eslint-config-prettier", "prettier"],
      "description": "Code linting and formatting"
    },
    "typescript": {
      "packages": [],
      "devDependencies": ["typescript", "@types/node", "ts-node"],
      "description": "TypeScript support"
    }
  },
  "projectTemplates": {
    "frontend": {
      "description": "Frontend web application",
      "defaultFramework": "react",
      "defaultStyling": "tailwind"
    },
    "backend": {
      "description": "Backend API server",
      "defaultFramework": "express",
      "defaultDatabase": "mongodb"
    },
    "fullstack": {
      "description": "Full-stack web application",
      "defaultFramework": "next",
      "defaultStyling": "tailwind",
      "defaultDatabase": "mongodb"
    },
    "mobile": {
      "description": "Mobile application",
      "defaultFramework": "react-native",
      "defaultStyling": "native"
    }
  }
